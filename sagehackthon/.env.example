# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# n8n Webhook URL (required for chatbot)
VITE_N8N_WEBHOOK_URL=https://your-name.app.n8n.cloud/webhook/your-webhook-id

# Gemini API Key (optional fallback)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API base URL
VITE_API_URL=https://api.eduinsight.ai/v1
